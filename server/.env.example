# Moro Analytics — server environment variables
# Copia questo file in .env e compila i valori

# ── SMTP (lascia vuoto per DEMO_MODE: OTP nel JSON) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@tuazienda.it
SMTP_PASS=app_password_qui
SMTP_FROM=security@moro.it
# SMTP_SECURE=false → STARTTLS porta 587 (= MAIL_ENCRYPTION=tls)
# SMTP_SECURE=true  → SSL diretto porta 465
SMTP_SECURE=false

# ── API ────────────────────────────────────────────────────────────────────────
PORT=5001

# ── URL pubblico del frontend (usato nei link email di attivazione) ───────────
# In produzione impostare il dominio reale; in sviluppo si usa il fallback localhost.
FRONTEND_URL=https://marginview.it

# ── Percorso assoluto del file SQLite ─────────────────────────────────────────
# Di default: stessa cartella di server/index.js (server/database.sqlite).
# Su Hostinger conviene puntare a una directory esterna al progetto per
# evitare che deploy/git-reset possano cancellare il database.
# Esempio: DATABASE_PATH=/home/u976446016/databases/marginview.sqlite
# DATABASE_PATH=

# ── CORS: domini consentiti (virgola-separati) ────────────────────────────────
# CORS_ORIGIN=https://margin-analysis.moro.it,https://www.moro.it

# ── Deploy webhook (lascia vuoto per disabilitare) ────────────────────────────
# Genera un token sicuro con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DEPLOY_SECRET=metti_qui_un_token_lungo_e_casuale
